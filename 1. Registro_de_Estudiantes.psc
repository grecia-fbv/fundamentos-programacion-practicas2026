Algoritmo Registro_de_Estudiantes
	Definir nombre_completo, carrera Como Cadena
	Definir edad, semestre Como Entero
	Escribir 'Ingrese su nombre completo'
	Leer nombre_completo
	Escribir 'Digite su edad'
	Leer edad
	Escribir 'Carrera'
	Leer carrera
	Escribir 'Escriba el semestre que está cursando'
	Leer semestre
	Escribir 'Nombre completo: ', nombre_completo
	Escribir 'Edad: ', edad
	Escribir 'Carrera: ', carrera
	Escribir 'Semestre: ', semestre
FinAlgoritmo
