Algoritmo Promedio_de_Notas
	
	Definir nota_1, nota_2, nota_3, nota_final Como Real
	
	Escribir "Ponga su primer calificación"
	Leer nota_1
	
	Escribir "Ponga su segunda calificación"
	Leer nota_2
	
	Escribir "Ponga su tercer calificación"
	Leer nota_3
	
	nota_final=(nota_1+nota_2+nota_3)/3
	Escribir "Su nota final es ", nota_final
	
FinAlgoritmo
